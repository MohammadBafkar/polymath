{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MohammadBafkar/Polymath/blob/main/registry/schemas/artifacts/Threat-model.schema.json",
  "title": "Polymath STRIDE threat model frontmatter",
  "description": "Validates only the YAML frontmatter block of a Threat-model.md.",
  "type": "object",
  "additionalProperties": true,
  "required": ["artifact", "system", "scope", "owner", "created", "stride_categories"],
  "properties": {
    "artifact": { "const": "ThreatModel" },
    "schemaVersion": { "type": "number", "enum": [0.1] },
    "system": { "type": "string", "minLength": 1 },
    "scope": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "created": { "type": "string", "format": "date" },
    "reviewers": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "stride_categories": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "Spoofing",
          "Tampering",
          "Repudiation",
          "InformationDisclosure",
          "DenialOfService",
          "ElevationOfPrivilege"
        ]
      },
      "uniqueItems": true
    },
    "data_classification": {
      "type": "string",
      "enum": ["public", "internal", "confidential", "restricted"]
    }
  }
}
