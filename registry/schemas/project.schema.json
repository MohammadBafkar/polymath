{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/MohammadBafkar/Polymath/blob/main/registry/schemas/project.schema.json",
  "title": "Polymath project context",
  "description": "Project-level localization for `.polymath/project.yaml`. Loaded by the polymath-core SessionStart hook and exposed to all skills as a resolved JSON snapshot under `${CLAUDE_PLUGIN_DATA}/polymath-core/project-context.json`. Lets a project tell Polymath what stack it uses (language, framework, testing tools), what conventions it follows (commit style, code-review checklist), which external skill catalogs to surface, and how to override specific skill behavior (additional review axes, test commands). Capability resolution is owned by `.polymath/capabilities.yaml` (separate file, separate schema); this file may reference it via `capabilities.inherit_from` but does not duplicate the data. The schema is intentionally minimal — start with the fields here, extend conservatively as patterns prove out.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion"],
  "properties": {
    "schemaVersion": {
      "description": "Schema version. v1 is the only supported version.",
      "type": "integer",
      "const": 1
    },
    "project": {
      "description": "Identification + a one-line description surfaced in the SessionStart welcome.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1, "maxLength": 80 },
        "description": { "type": "string", "maxLength": 240 }
      }
    },
    "stack": {
      "description": "What this project is built on. Skills that adapt to language / framework read these fields.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "languages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["lang"],
            "properties": {
              "lang": { "type": "string", "pattern": "^[a-z][a-z0-9_+-]*$" },
              "version": { "type": "string", "maxLength": 32 },
              "framework": { "type": "string", "maxLength": 80 }
            }
          }
        },
        "testing": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["framework"],
            "properties": {
              "framework": { "type": "string", "maxLength": 80 },
              "mocking": { "type": "string", "maxLength": 80 },
              "assertion": { "type": "string", "maxLength": 80 }
            }
          }
        },
        "build": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "primary": { "type": "string", "maxLength": 80 },
            "secondary": { "type": "string", "maxLength": 80 }
          }
        },
        "runtime": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "maxLength": 80 },
            "namespace": { "type": "string", "maxLength": 80 },
            "manifests": { "type": "string", "maxLength": 200 }
          }
        },
        "database": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "primary": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "kind": { "type": "string", "maxLength": 80 },
                "version": { "type": "string", "maxLength": 32 }
              }
            }
          }
        },
        "package_manager": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": { "type": "string", "maxLength": 80 },
            "lock_file": { "type": "string", "maxLength": 200 }
          }
        }
      }
    },
    "conventions": {
      "description": "House rules: commit style, code-review checklist, branch strategy, language-specific style files.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "code_review_checklist": { "type": "string", "maxLength": 200 },
        "commit_style": {
          "type": "string",
          "enum": ["conventional-commits", "free-form", "ticket-prefixed"]
        },
        "branch_strategy": {
          "type": "string",
          "enum": ["trunk-based", "gitflow", "github-flow", "release-branch"]
        },
        "api_style_guide": { "type": "string", "maxLength": 200 },
        "language_specific": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "file": { "type": "string", "maxLength": 200 }
            }
          }
        }
      }
    },
    "external_skills": {
      "description": "External skill catalogs (e.g. dotnet/skills, laravel/boost) that this project recommends. SessionStart surfaces these so contributors discover them; install is out-of-band (catalog-specific).",
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source"],
        "properties": {
          "source": { "type": "string", "minLength": 1, "maxLength": 240 },
          "plugins": {
            "type": "array",
            "items": { "type": "string", "minLength": 1, "maxLength": 80 }
          },
          "install": {
            "type": "string",
            "enum": ["marketplace", "manual", "submodule"]
          },
          "when": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "language": { "type": "string", "maxLength": 32 }
            }
          }
        }
      }
    },
    "capabilities": {
      "description": "Pointer to `.polymath/capabilities.yaml` so capability resolution can find a non-default location. The actual capability data lives in that file; not duplicated here.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "inherit_from": { "type": "string", "minLength": 1, "maxLength": 200 }
      }
    },
    "setup": {
      "description": "Onboarding and local setup metadata inferred from README, AGENTS.md, CLAUDE.md, docs, CI, and project config files. Used to tell coding agents which context to read, which tools to check, which environment variables matter, and what first steps a new contributor should take.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "context_sources": {
          "description": "Repo files an agent should read first for project-specific expectations.",
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 200 }
        },
        "required_tools": {
          "description": "Tools expected in the local environment.",
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "minLength": 1, "maxLength": 80 },
              "version": { "type": "string", "maxLength": 80 },
              "check": { "type": "string", "maxLength": 200 },
              "required": { "type": "boolean", "default": true }
            }
          }
        },
        "environment": {
          "description": "Environment variables, API keys, and tokens a contributor may need. Sensitive values are named only; never store values here.",
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "pattern": "^[A-Z][A-Z0-9_]*$" },
              "purpose": { "type": "string", "maxLength": 240 },
              "required": { "type": "boolean", "default": false },
              "sensitive": { "type": "boolean", "default": true }
            }
          }
        },
        "first_steps": {
          "description": "Concrete first actions after installing the recommended plugins.",
          "type": "array",
          "items": { "type": "string", "minLength": 1, "maxLength": 240 }
        }
      }
    },
    "polymath": {
      "description": "Polymath-specific activation hints: recommended plugins, workflows, and compatible agent surfaces for this repository.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "recommended_plugins": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
              "reason": { "type": "string", "maxLength": 240 },
              "required": { "type": "boolean", "default": false }
            }
          }
        },
        "recommended_workflows": {
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z][a-zA-Z0-9]*$" }
        },
        "compatible_agents": {
          "description": "Agent or IDE surfaces the project explicitly supports. Capabilities vary by surface; see docs/PORTABILITY.md.",
          "type": "array",
          "uniqueItems": true,
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" }
        }
      }
    },
    "skill_overrides": {
      "description": "Per-skill customization. Key is `<plugin>:<skill>`. Each entry may declare additional context files, additional review axes, or test commands the skill should run.",
      "type": "object",
      "additionalProperties": false,
      "patternProperties": {
        "^[a-z0-9-]+:[a-z][a-z0-9-]*$": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "additional_context": {
              "type": "array",
              "items": { "type": "string", "minLength": 1, "maxLength": 200 }
            },
            "additional_axes": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["axis", "prompt"],
                "properties": {
                  "axis": { "type": "string", "minLength": 1, "maxLength": 80 },
                  "prompt": { "type": "string", "minLength": 1, "maxLength": 600 }
                }
              }
            },
            "test_commands": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["cmd"],
                "properties": {
                  "language": { "type": "string", "maxLength": 32 },
                  "cmd": { "type": "string", "minLength": 1, "maxLength": 600 }
                }
              }
            }
          }
        }
      }
    },
    "prompts": {
      "description": "Pointers to project-owned prompt templates that skills should prefer over their built-in templates.",
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pr_description_template": { "type": "string", "maxLength": 200 },
        "postmortem_template": { "type": "string", "maxLength": 200 },
        "prd_template": { "type": "string", "maxLength": 200 },
        "adr_template": { "type": "string", "maxLength": 200 }
      }
    }
  }
}
