{
  "mcpServers": {
    "grafana": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@grafana/mcp-server"],
      "env": {
        "GRAFANA_URL": "${POLYMATH_CONNECTOR_GRAFANA_GRAFANAURL}",
        "GRAFANA_API_KEY": "${POLYMATH_CONNECTOR_GRAFANA_GRAFANAAPIKEY}"
      }
    }
  }
}
