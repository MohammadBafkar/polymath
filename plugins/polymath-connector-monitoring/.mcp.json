{
  "mcpServers": {
    "grafana": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@grafana/mcp-server"],
      "env": {
        "GRAFANA_URL": "${POLYMATH_CONNECTOR_MONITORING_GRAFANAURL}",
        "GRAFANA_API_KEY": "${POLYMATH_CONNECTOR_MONITORING_GRAFANAAPIKEY}"
      }
    },
    "honeycomb": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@honeycomb/mcp-server"],
      "env": {
        "HONEYCOMB_API_KEY": "${POLYMATH_CONNECTOR_MONITORING_HONEYCOMBAPIKEY}",
        "HONEYCOMB_DATASET": "${POLYMATH_CONNECTOR_MONITORING_HONEYCOMBDATASET}"
      }
    },
    "elastic": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@elastic/mcp-server"],
      "env": {
        "ELASTIC_ENDPOINT": "${POLYMATH_CONNECTOR_MONITORING_ELASTICENDPOINT}",
        "ELASTIC_API_KEY": "${POLYMATH_CONNECTOR_MONITORING_ELASTICAPIKEY}"
      }
    }
  }
}
