{
  "mcpServers": {
    "figma": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@figma/mcp-server"],
      "env": {
        "FIGMA_ACCESS_TOKEN": "${POLYMATH_CONNECTOR_FIGMA_FIGMAACCESSTOKEN}",
        "FIGMA_TEAM_ID": "${POLYMATH_CONNECTOR_FIGMA_FIGMATEAMID}"
      }
    }
  }
}
