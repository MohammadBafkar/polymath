{
  "mcpServers": {
    "jira": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-atlassian"],
      "env": {
        "ATLASSIAN_URL": "${POLYMATH_CONNECTOR_JIRA_JIRAURL}",
        "ATLASSIAN_EMAIL": "${POLYMATH_CONNECTOR_JIRA_JIRAEMAIL}",
        "ATLASSIAN_API_TOKEN": "${POLYMATH_CONNECTOR_JIRA_JIRAAPITOKEN}"
      }
    }
  }
}
