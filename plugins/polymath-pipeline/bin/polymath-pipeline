#!/usr/bin/env python3
"""polymath-pipeline — opt-in routing pipeline engine.

Activates ONLY when the project's `.polymath/project.yaml` (or its
`project.local.yaml` overlay) declares `routing.mode: classify` or
`enforce`. A repo without that declaration costs three constant-time
early-exits per session (one per hook) and nothing else; `hint` mode is
exactly today's polymath-core behavior, owned by polymath-core.

Owns:
  - the shared root resolver: the nearest ancestor of cwd carrying
    `.polymath/project.yaml`, stopping at the repo boundary (`.git`) and
    REFUSING `$HOME` and `${CLAUDE_CONFIG_DIR}` as roots — a user-layer
    default must never flip every shell into pipeline mode
  - per-invocation, session-namespaced markers under
    `${CLAUDE_PLUGIN_DATA}/markers/<session>.json`: the prompt hook stamps
    `directive-issued`; `mark` upgrades the newest marker for the root to
    `classified` (1h validity)
  - the decision log `${CLAUDE_PLUGIN_DATA}/decisions.jsonl` (append-only
    audit: classify-directive, classified, enforce-deny, kill-switch,
    fail-open, policy-overlay events, sweep) + a deterministic retention
    sweep (markers > 7 days pruned; log truncated to its newest 1000 lines
    past 512 KiB)
  - the enforce-gate tool policy: gated tools (Edit/Write/MultiEdit/
    NotebookEdit/Task), the Bash modify-pattern blacklist, and MCP tool
    classification (default gated; read-only verb names exempt). Base
    policy ships in data/tool-policy.json (mirrored by code constants);
    a project may STRENGTHEN it via .polymath/tool-policy.json — never
    weaken it
  - the three hook entrypoints (hook-session-start, hook-prompt,
    hook-pretool) — see hooks/hooks.json

Trust contract: in classify/enforce mode the directive HONORS
`trust: auto-headless` for read-only surfaces (minimum intervention) —
the first consumer of the declared trust axis. Everything else keeps the
propose-first contract.

Exit codes: hooks exit 0 (fail-open) except an enforce-gate DENY, which
exits 2 with the reason on stderr (the PreToolUse blocking contract).
Every fail-open and every kill-switch use is audited to the decision log.
"""

from __future__ import annotations

import argparse
import datetime
import json
import os
import pathlib
import re
import sys
from typing import Any

CLASSIFIED_TTL_SECONDS = 3600       # 1h: how long a classification stays fresh
MARKER_RETENTION_DAYS = 7           # markers older than this are swept
LOG_SWEEP_BYTES = 512 * 1024        # sweep decisions.jsonl past this size
LOG_KEEP_LINES = 1000               # ...down to its newest N lines
MODES = {"hint", "classify", "enforce"}


def _now() -> datetime.datetime:
    return datetime.datetime.now(datetime.timezone.utc)


def _now_iso() -> str:
    return _now().replace(microsecond=0).isoformat()


def _parse_iso(ts: str | None) -> datetime.datetime | None:
    if not ts:
        return None
    try:
        d = datetime.datetime.fromisoformat(str(ts).replace("Z", "+00:00"))
        return d if d.tzinfo else d.replace(tzinfo=datetime.timezone.utc)
    except Exception:
        return None


# ---------------------------------------------------------------------------
# Shared root resolver + mode reader
# ---------------------------------------------------------------------------


def _excluded_roots() -> set[pathlib.Path]:
    excluded = {pathlib.Path.home()}
    cfg = os.environ.get("CLAUDE_CONFIG_DIR")
    if cfg:
        excluded.add(pathlib.Path(cfg))
    return {p.resolve() for p in excluded}


def resolve_root(start: pathlib.Path | None = None) -> pathlib.Path | None:
    """Nearest ancestor of `start` (default cwd) with .polymath/project.yaml.
    Stops after the first `.git` boundary; $HOME and ${CLAUDE_CONFIG_DIR}
    are never acceptable roots."""
    here = (start or pathlib.Path.cwd()).resolve()
    excluded = _excluded_roots()
    for d in (here, *here.parents):
        if d in excluded:
            return None
        try:
            if (d / ".polymath" / "project.yaml").is_file():
                return d
            if (d / ".git").exists():
                return None  # repo boundary without a project file
        except OSError:
            return None
    return None


_MODE_RE = re.compile(r"^[ \t]+mode:[ \t]*['\"]?(hint|classify|enforce)['\"]?[ \t]*(#.*)?$")
_MODE_ANY_RE = re.compile(r"^[ \t]+mode:[ \t]*(\S.*?)[ \t]*$")
_ROUTING_RE = re.compile(r"^routing:[ \t]*(#.*)?$")
_ROUTING_FLOW_RE = re.compile(r"^routing:[ \t]*[^#\s]")
_TOP_KEY_RE = re.compile(r"^[A-Za-z_]")


def _scan_mode(path: pathlib.Path) -> str | None:
    """Line-scan one YAML file for the routing.mode value. No PyYAML —
    a hook must not depend on the environment having it."""
    try:
        text = path.read_text(errors="ignore")
    except OSError:
        return None
    in_routing = False
    for line in text.splitlines():
        if _ROUTING_RE.match(line):
            in_routing = True
            continue
        if in_routing:
            m = _MODE_RE.match(line)
            if m:
                return m.group(1)
            if _TOP_KEY_RE.match(line):
                in_routing = False  # left the routing block
    return None


def config_diagnostics(root: pathlib.Path) -> list[str]:
    """Routing declarations the line-scan cannot honor — these must be
    LOUD, not silently read as hint: a flow-style `routing: {…}` line, or
    a `mode:` inside the routing block with an unknown value."""
    problems: list[str] = []
    for name in ("project.local.yaml", "project.yaml"):
        path = root / ".polymath" / name
        try:
            text = path.read_text(errors="ignore")
        except OSError:
            continue
        in_routing = False
        for line in text.splitlines():
            if _ROUTING_FLOW_RE.match(line):
                problems.append(
                    f"{name}: flow-style `{line.strip()}` is not supported — "
                    f"use block form (routing:\\n  mode: hint|classify|enforce)"
                )
                continue
            if _ROUTING_RE.match(line):
                in_routing = True
                continue
            if in_routing:
                if _MODE_RE.match(line):
                    in_routing = False
                    continue
                m = _MODE_ANY_RE.match(line)
                if m and m.group(1).split("#", 1)[0].strip().strip("'\"") not in MODES:
                    problems.append(
                        f"{name}: routing.mode {m.group(1)!r} is not one of "
                        f"hint|classify|enforce — treated as hint"
                    )
                    in_routing = False
                    continue
                if _TOP_KEY_RE.match(line):
                    in_routing = False
    return problems


def read_mode(root: pathlib.Path) -> str:
    """routing.mode for the project, overlay-aware (the gitignored
    project.local.yaml wins per key, matching the loader's merge policy).
    Absent or unknown → 'hint' (the pipeline stays dormant); declarations
    the scan cannot honor are surfaced by config_diagnostics()."""
    for name in ("project.local.yaml", "project.yaml"):
        mode = _scan_mode(root / ".polymath" / name)
        if mode in MODES:
            return mode
    return "hint"


# ---------------------------------------------------------------------------
# Kill switch (audited by callers)
# ---------------------------------------------------------------------------


def kill_switch(root: pathlib.Path | None) -> str | None:
    """Return a short reason when the pipeline is switched off, else None."""
    if os.environ.get("POLYMATH_PIPELINE_OFF"):
        return "env POLYMATH_PIPELINE_OFF"
    if root is not None and (root / ".polymath" / "pipeline-off").exists():
        return ".polymath/pipeline-off marker"
    return None


# ---------------------------------------------------------------------------
# Data root, markers, decision log, sweep
# ---------------------------------------------------------------------------


def data_root() -> pathlib.Path:
    base = os.environ.get("CLAUDE_PLUGIN_DATA")
    if base:
        return pathlib.Path(base)
    return pathlib.Path.home() / ".claude" / "plugins" / "data" / "polymath-pipeline"


def _markers_dir() -> pathlib.Path:
    return data_root() / "markers"


def _log_path() -> pathlib.Path:
    return data_root() / "decisions.jsonl"


_SESSION_SAFE_RE = re.compile(r"[^A-Za-z0-9._-]")


def _marker_path(session: str) -> pathlib.Path:
    return _markers_dir() / f"{_SESSION_SAFE_RE.sub('_', session)[:128]}.json"


def log_decision(event: str, **fields: Any) -> None:
    """Append one audit line. Fail-open: an unwritable log never blocks."""
    try:
        path = _log_path()
        path.parent.mkdir(parents=True, exist_ok=True)
        line = json.dumps({"ts": _now_iso(), "event": event, **fields}, ensure_ascii=False)
        with path.open("a") as f:
            f.write(line + "\n")
    except Exception:
        pass


def read_marker(session: str) -> dict | None:
    try:
        doc = json.loads(_marker_path(session).read_text())
        return doc if isinstance(doc, dict) else None
    except Exception:
        return None


def touch_marker(session: str, root: pathlib.Path, mode: str) -> dict:
    """Per-invocation stamp from the prompt hook. Preserves an existing
    fresh classification; a root change invalidates it (new project,
    new classification)."""
    marker = read_marker(session) or {}
    if marker.get("root") != str(root):
        marker = {}
    marker.setdefault("session", session)
    marker.setdefault("first_seen", _now_iso())
    marker["root"] = str(root)
    marker["mode"] = mode
    marker["last_prompt"] = _now_iso()
    marker["prompts"] = int(marker.get("prompts", 0)) + 1
    try:
        _markers_dir().mkdir(parents=True, exist_ok=True)
        _marker_path(session).write_text(json.dumps(marker, indent=2))
    except Exception:
        pass
    return marker


def _classified_fresh(marker: dict | None) -> bool:
    if not marker:
        return False
    ts = _parse_iso(marker.get("classified_at"))
    if ts is None:
        return False
    return (_now() - ts).total_seconds() <= CLASSIFIED_TTL_SECONDS


def fresh_classification(session: str, root: pathlib.Path) -> dict | None:
    """The session's own fresh classified marker, else any fresh classified
    marker for the same root. Markers are stored session-namespaced, but
    acceptance is root-scoped within the 1h TTL: `mark` runs through the
    Bash tool, which cannot know the harness session id."""
    own = read_marker(session)
    if own and own.get("root") == str(root) and _classified_fresh(own):
        return own
    try:
        candidates = sorted(
            _markers_dir().glob("*.json"), key=lambda p: p.stat().st_mtime, reverse=True
        )
    except OSError:
        return None
    for path in candidates:
        try:
            doc = json.loads(path.read_text())
        except Exception:
            continue
        if isinstance(doc, dict) and doc.get("root") == str(root) and _classified_fresh(doc):
            return doc
    return None


def mark_classified(
    root: pathlib.Path, surface: str | None, session: str | None = None
) -> dict | None:
    """Record a classification. With a session id (the directive bakes one
    into the mark command) the marker is attributed to THAT session; without
    one, upgrade the NEWEST marker for this root, creating a root-scoped one
    when none exists (hook missed, headless run)."""
    newest: pathlib.Path | None = None
    marker: dict = {}
    if session:
        marker = read_marker(session) or {}
        if marker.get("root") not in (None, str(root)):
            marker = {}
        marker.setdefault("session", session)
        marker.setdefault("first_seen", _now_iso())
        marker.setdefault("prompts", 0)
        marker["root"] = str(root)
        newest = _marker_path(session)
    else:
        try:
            for path in sorted(
                _markers_dir().glob("*.json"), key=lambda p: p.stat().st_mtime, reverse=True
            ):
                try:
                    doc = json.loads(path.read_text())
                except Exception:
                    continue
                if isinstance(doc, dict) and doc.get("root") == str(root):
                    newest = path
                    marker = doc
                    break
        except OSError:
            pass
        if newest is None:
            marker = {
                "session": f"cli-{os.getpid()}",
                "root": str(root),
                "first_seen": _now_iso(),
                "prompts": 0,
            }
            newest = _marker_path(marker["session"])
    marker["classified_at"] = _now_iso()
    if surface:
        marker["classified_surface"] = surface
    try:
        _markers_dir().mkdir(parents=True, exist_ok=True)
        newest.write_text(json.dumps(marker, indent=2))
    except Exception:
        return None
    return marker


# ---------------------------------------------------------------------------
# Surface catalog (mark validation)
# ---------------------------------------------------------------------------


def _sibling_plugins_root() -> pathlib.Path | None:
    """Directory containing the sibling Polymath plugins, for both layouts:
    repo checkout (plugins/<name>/…) and the install cache
    (<cache>/polymath/<name>/<version>/…)."""
    plugin_root = pathlib.Path(__file__).resolve().parent.parent
    if plugin_root.parent.name == "plugins":
        return plugin_root.parent
    if plugin_root.parent.name == "polymath-pipeline":
        return plugin_root.parent.parent
    return None


def surface_catalog() -> tuple[set[str], set[str]] | None:
    """(skills, workflows) across sibling plugins, or None when siblings
    are unresolvable — the caller must FAIL OPEN then (a standalone
    install of this plugin must not make `mark` unusable)."""
    base = _sibling_plugins_root()
    if base is None or not base.is_dir():
        return None
    skills: set[str] = set()
    workflows: set[str] = set()
    try:
        for plugin_dir in base.iterdir():
            if not plugin_dir.is_dir() or plugin_dir.name.startswith("."):
                continue
            candidates = [plugin_dir]
            try:
                candidates += [d for d in plugin_dir.iterdir() if d.is_dir()]
            except OSError:
                pass
            for cand in candidates:
                sdir = cand / "skills"
                if sdir.is_dir():
                    for skill in sdir.iterdir():
                        if (skill / "SKILL.md").is_file():
                            skills.add(f"{plugin_dir.name}:{skill.name}")
                wdir = cand / "workflows"
                if wdir.is_dir():
                    for wf in wdir.glob("*.yaml"):
                        workflows.add(wf.stem)
    except OSError:
        return None
    if not skills and not workflows:
        return None
    return skills, workflows


def validate_surface(surface: str) -> tuple[bool, str | None]:
    """(accepted, reason-if-rejected). 'direct', any catalog skill
    (<plugin>:<skill>), any workflow name, or the surface-index workflow
    form ('polymath-flows:run-workflow <name>') pass. Unresolvable
    catalog → fail open (accept)."""
    if surface == "direct":
        return True, None
    catalog = surface_catalog()
    if catalog is None:
        return True, None
    skills, workflows = catalog
    if surface in skills or surface in workflows:
        return True, None
    head, _, tail = surface.partition(" ")
    if tail and head.endswith(":run-workflow") and tail in workflows:
        return True, None
    return False, (
        f"unknown surface {surface!r} — expected 'direct', a catalog skill "
        f"(<plugin>:<skill>), or a workflow name"
    )


def sweep() -> dict:
    """Retention: prune markers older than MARKER_RETENTION_DAYS; truncate
    the decision log to its newest LOG_KEEP_LINES once past LOG_SWEEP_BYTES."""
    removed = 0
    cutoff = _now() - datetime.timedelta(days=MARKER_RETENTION_DAYS)
    try:
        for path in _markers_dir().glob("*.json"):
            try:
                mtime = datetime.datetime.fromtimestamp(
                    path.stat().st_mtime, tz=datetime.timezone.utc
                )
                if mtime < cutoff:
                    path.unlink()
                    removed += 1
            except OSError:
                continue
    except OSError:
        pass
    truncated = False
    try:
        log = _log_path()
        if log.is_file() and log.stat().st_size > LOG_SWEEP_BYTES:
            lines = log.read_text(errors="ignore").splitlines()[-LOG_KEEP_LINES:]
            log.write_text("\n".join(lines) + "\n")
            truncated = True
    except OSError:
        pass
    if removed or truncated:
        log_decision("sweep", markers_removed=removed, log_truncated=truncated)
    return {"markers_removed": removed, "log_truncated": truncated}


# ---------------------------------------------------------------------------
# Tool policy (enforce gate): Bash blacklist, gated tools, MCP classification
# ---------------------------------------------------------------------------

# Modify-pattern BLACKLIST: a Bash command matching any of these is treated
# as mutating and requires a fresh classification in enforce mode. The
# inverse (a read-only whitelist) is unwinnable; false positives — a
# read-only command matching a pattern — are accepted by design and only
# cost one classify round-trip.
MODIFY_PATTERNS = [
    r"[^<>]>{1,2}",                          # redirection (>, >>) but not <<heredoc / 2>&1 handled below
    r"\btee\b",
    r"\b(rm|mv|cp|mkdir|rmdir|touch|ln|chmod|chown|truncate|dd|install)\b",
    r"\b(sed|perl)\b[^|;&]*\s-[a-zA-Z]*i",   # in-place edit flags
    r"\bgit\b[^|;&]*\b(commit|push|merge|rebase|reset|checkout|switch|restore|cherry-pick|revert|tag|stash|clean|am|apply|rm|mv|init|clone|fetch|pull|remote|submodule|worktree|branch\s+(-d|-D|-m|-M))\b",
    r"\b(npm|yarn|pnpm|pip3?|uv|poetry|cargo|gem|brew|apt(-get)?|dnf|yum|composer)\b[^|;&]*\b(install|add|remove|rm|uninstall|update|upgrade|publish)\b",
    r"\bgo\b[^|;&]*\b(install|get|mod)\b",
    r"\b(curl|wget)\b[^|;&]*\s(-o|-O|--output|--remote-name)\b",
    r"\b(kill|pkill|killall)\b",
    r"\b(docker|podman|kubectl|helm|terraform|pulumi)\b[^|;&]*\b(run|apply|delete|create|scale|patch|edit|exec|up|destroy|push|build|rm|prune)\b",
    r"\b(systemctl|service|launchctl)\b",
    r"\beval\b|\bexec\b|\bsource\b|^\s*\.\s",
    r"\bcrontab\b",
    # Build/exec wrappers and transfer tools — each can write through a
    # name the patterns above never see. Command-position anchors keep
    # words like `make` in arguments exempt.
    r"(?:^|[|;&\n])\s*make\b",
    r"(?:^|[|;&\n])\s*(?:python3?|node|deno|bun|ruby|perl|bash|sh|zsh)\b[^|;&\n]*\s\S+\.(?:py|js|mjs|cjs|ts|rb|pl|sh|bash)\b",
    r"(?:^|[|;&\n])\s*npx\b",
    r"\bgh\b[^|;&\n]*\s(?:create|merge|close|reopen|edit|delete|comment|review|fork|sync|enable|disable|rerun|cancel|deploy|ready|lock|unlock|transfer|api|clone|set|workflow\s+run)\b",
    r"\b(?:az|gcloud|aws)\b[^|;&\n]*\s(?:create|delete|update|set|put|add|remove|start|stop|restart|deploy|scale|import|upload|purge|patch|assign|attach|detach|enable|disable|cp|mv|rm|sync|invoke|register|flush)\b",
    r"\b(?:psql|mysql|sqlite3|mongosh?|redis-cli)\b",
    r"\b(?:rsync|scp|sftp|unzip)\b",
    r"(?:^|[|;&\n])\s*patch\b",
    r"\btar\b\s+-{0,2}[A-Za-z]*[xcur]",
]
_MODIFY_RE = [re.compile(p) for p in MODIFY_PATTERNS]
# `2>&1`, `&>`, `>/dev/null` style noise that the redirection pattern would
# otherwise flag — stripped before matching so plain inspection commands
# (`grep x f 2>/dev/null`) stay exempt.
_HARMLESS_REDIRECT_RE = re.compile(r"\d?>{1,2}\s*(&\d|/dev/null|/dev/stderr|/dev/stdout)")


def bash_is_mutating(command: str, compiled: list[re.Pattern] | None = None) -> bool:
    cleaned = _HARMLESS_REDIRECT_RE.sub(" ", command)
    return any(rx.search(cleaned) for rx in (compiled if compiled is not None else _MODIFY_RE))


GATED_TOOLS = {"Edit", "Write", "MultiEdit", "NotebookEdit", "Task"}

# MCP tools default to GATED — an MCP tool is an arbitrary external action
# behind an unbounded namespace. A tool passes only when its name
# classifies as read-only: take the segment after the last `__`, split on
# underscores / hyphens / camelCase, walk segments left to right; the
# FIRST segment that is a known verb decides. No known verb → gated
# (false positives cost one classify round-trip; false negatives are the
# failure mode this gate exists to close).
MCP_MUTATING_VERBS = {
    "accept", "add", "apply", "approve", "archive", "assign", "ban",
    "cancel", "clone", "close", "comment", "complete", "create", "delete",
    "deploy", "destroy", "disable", "dismiss", "download", "edit",
    "enable", "execute", "fork", "generate", "grant", "import", "insert",
    "install", "invite", "kill", "link", "lock", "mark", "merge", "move",
    "mute", "patch", "post", "publish", "purge", "push", "put", "reject",
    "remove", "rename", "reopen", "reorder", "reply", "rerun", "resolve",
    "restore", "retry", "revoke", "run", "scale", "send", "set", "start",
    "stop", "submit", "sync", "transfer", "trigger", "unassign",
    "uninstall", "unlink", "unlock", "update", "upload", "upsert", "use",
    "vote", "write",
}
MCP_READONLY_VERBS = {
    "browse", "check", "count", "describe", "explore", "fetch", "find",
    "get", "info", "list", "lookup", "preview", "query", "read", "render",
    "search", "show", "status", "summary", "validate", "view", "watch",
    "whoami",
}
_CAMEL_BOUNDARY_RE = re.compile(r"(?<=[a-z0-9])(?=[A-Z])")


def _mcp_segments(tool_name: str) -> list[str]:
    leaf = tool_name.rsplit("__", 1)[-1]
    leaf = _CAMEL_BOUNDARY_RE.sub("_", leaf).replace("-", "_").lower()
    return [s for s in leaf.split("_") if s]


def mcp_is_gated(tool_name: str, policy: dict) -> bool:
    for rx in policy["mcp_gated_res"]:
        if rx.search(tool_name):
            return True
    for seg in _mcp_segments(tool_name):
        if seg in policy["mcp_mutating_verbs"]:
            return True
        if seg in policy["mcp_readonly_verbs"]:
            return False
    return True


# Canonical BASE policy. data/tool-policy.json ships the same values as a
# machine-readable mirror (a unit test pins the two equal); the JSON file
# is read first so an org fork can edit policy without touching code, and
# these constants are the fail-safe when that file is unreadable.
TOOL_POLICY_FALLBACK = {
    "gatedTools": sorted(GATED_TOOLS),
    "bashModifyPatterns": list(MODIFY_PATTERNS),
    "mcpGatedPatterns": [],
    "mcpMutatingVerbs": sorted(MCP_MUTATING_VERBS),
    "mcpReadOnlyVerbs": sorted(MCP_READONLY_VERBS),
}
# A project overlay (.polymath/tool-policy.json) is STRENGTHEN-ONLY: it can
# add gated tools, add Bash modify patterns, add MCP gated patterns or
# mutating verbs — never exempt anything. Keys outside this set (e.g. an
# attempt to extend mcpReadOnlyVerbs) are ignored and audited.
OVERLAY_KEYS = {"gatedTools", "bashModifyPatterns", "mcpGatedPatterns", "mcpMutatingVerbs"}


def _base_policy_path() -> pathlib.Path:
    return pathlib.Path(__file__).resolve().parent.parent / "data" / "tool-policy.json"


def load_tool_policy(root: pathlib.Path | None) -> dict:
    raw: dict | None = None
    try:
        doc = json.loads(_base_policy_path().read_text())
        if isinstance(doc, dict) and doc.get("gatedTools"):
            raw = doc
    except Exception:
        pass
    if raw is None:
        raw = TOOL_POLICY_FALLBACK
    policy: dict = {
        "gated_tools": {str(x) for x in raw.get("gatedTools") or []},
        "bash_patterns": [str(x) for x in raw.get("bashModifyPatterns") or []],
        "mcp_gated_patterns": [str(x) for x in raw.get("mcpGatedPatterns") or []],
        "mcp_mutating_verbs": {str(x).lower() for x in raw.get("mcpMutatingVerbs") or []},
        "mcp_readonly_verbs": {str(x).lower() for x in raw.get("mcpReadOnlyVerbs") or []},
    }
    if root is not None:
        overlay_path = root / ".polymath" / "tool-policy.json"
        if overlay_path.is_file():
            try:
                doc = json.loads(overlay_path.read_text())
                if not isinstance(doc, dict):
                    raise ValueError("overlay must be a JSON object")
                ignored = sorted(set(doc) - OVERLAY_KEYS - {"schemaVersion", "description"})
                policy["gated_tools"] |= {str(x) for x in doc.get("gatedTools") or []}
                policy["bash_patterns"] += [str(x) for x in doc.get("bashModifyPatterns") or []]
                policy["mcp_gated_patterns"] += [str(x) for x in doc.get("mcpGatedPatterns") or []]
                policy["mcp_mutating_verbs"] |= {
                    str(x).lower() for x in doc.get("mcpMutatingVerbs") or []
                }
                if ignored:
                    log_decision("policy-overlay-ignored", root=str(root), keys=ignored)
            except Exception:
                log_decision("policy-overlay-invalid", root=str(root))
    for src_key, dst_key in (("bash_patterns", "bash_res"), ("mcp_gated_patterns", "mcp_gated_res")):
        compiled = []
        for pat in policy[src_key]:
            try:
                compiled.append(re.compile(pat))
            except re.error:
                log_decision("policy-bad-pattern", pattern=pat[:100])
        policy[dst_key] = compiled
    return policy


# ---------------------------------------------------------------------------
# Feedback loop — capture (conservative, 180d TTL) → evaluate → resolve
# ---------------------------------------------------------------------------

FEEDBACK_TTL_DAYS = 180
FEEDBACK_KINDS = {"correction", "gap", "friction", "praise"}
FEEDBACK_VERDICTS = {"valid-constructive", "valid-not-actionable", "invalid"}
FEEDBACK_OUTCOMES = {"applied", "rejected", "proposed-catalog-patch"}


def _feedback_path() -> pathlib.Path:
    return data_root() / "feedback.jsonl"


def _feedback_append(record: dict) -> bool:
    try:
        path = _feedback_path()
        path.parent.mkdir(parents=True, exist_ok=True)
        with path.open("a") as f:
            f.write(json.dumps(record, ensure_ascii=False) + "\n")
        return True
    except Exception:
        return False


def _feedback_events() -> list[dict]:
    try:
        out = []
        for line in _feedback_path().read_text(errors="ignore").splitlines():
            try:
                doc = json.loads(line)
            except Exception:
                continue
            if isinstance(doc, dict):
                out.append(doc)
        return out
    except OSError:
        return []


def feedback_items(now: datetime.datetime | None = None) -> list[dict]:
    """Event-sourced view: one item per capture id with its latest verdict
    and resolution folded in. Items captured more than FEEDBACK_TTL_DAYS
    ago are excluded — feedback is a perishable signal, not an archive."""
    now = now or _now()
    cutoff = now - datetime.timedelta(days=FEEDBACK_TTL_DAYS)
    items: dict[str, dict] = {}
    for ev in _feedback_events():
        event, fid = ev.get("event"), ev.get("id")
        if not fid:
            continue
        if event == "capture":
            ts = _parse_iso(ev.get("ts"))
            if ts is None or ts < cutoff:
                continue
            items[fid] = {
                "id": fid,
                "ts": ev.get("ts"),
                "surface": ev.get("surface"),
                "kind": ev.get("kind"),
                "note": ev.get("note"),
                "evidence": ev.get("evidence"),
                "root": ev.get("root"),
                "state": "captured",
            }
        elif event == "evaluate" and fid in items:
            items[fid]["verdict"] = ev.get("verdict")
            items[fid]["verdict_evidence"] = ev.get("evidence")
            items[fid]["state"] = "evaluated"
        elif event == "resolve" and fid in items:
            items[fid]["outcome"] = ev.get("outcome")
            items[fid]["outcome_detail"] = ev.get("detail")
            items[fid]["state"] = "resolved"
    return sorted(items.values(), key=lambda i: str(i.get("ts")))


def feedback_sweep() -> int:
    """Drop all events belonging to captures older than the TTL. Returns
    the number of items removed."""
    events = _feedback_events()
    cutoff = _now() - datetime.timedelta(days=FEEDBACK_TTL_DAYS)
    live_ids = set()
    expired_ids = set()
    for ev in events:
        if ev.get("event") == "capture" and ev.get("id"):
            ts = _parse_iso(ev.get("ts"))
            (live_ids if (ts is not None and ts >= cutoff) else expired_ids).add(ev["id"])
    if not expired_ids:
        return 0
    kept = [ev for ev in events if ev.get("id") in live_ids]
    try:
        _feedback_path().write_text(
            "".join(json.dumps(ev, ensure_ascii=False) + "\n" for ev in kept)
        )
    except OSError:
        return 0
    return len(expired_ids)


def cmd_feedback_capture(args: argparse.Namespace) -> int:
    import hashlib

    if args.kind not in FEEDBACK_KINDS:
        print(json.dumps({"captured": False, "reason": f"kind must be one of {sorted(FEEDBACK_KINDS)}"}))
        return 2
    note = (args.note or "").strip()
    if not note:
        print(json.dumps({"captured": False, "reason": "a non-empty --note is required"}))
        return 2
    root = resolve_root(pathlib.Path(args.cwd) if args.cwd else None)
    ts = _now_iso()
    fid = hashlib.sha256(f"{ts}|{args.surface}|{note}".encode()).hexdigest()[:10]
    ok = _feedback_append({
        "ts": ts,
        "event": "capture",
        "id": fid,
        "surface": args.surface,
        "kind": args.kind,
        "note": note[:500],
        "evidence": (args.evidence or "")[:500] or None,
        "root": str(root) if root else None,
    })
    print(json.dumps({"captured": ok, "id": fid if ok else None, "ttl_days": FEEDBACK_TTL_DAYS}))
    return 0 if ok else 1


def cmd_feedback_digest(args: argparse.Namespace) -> int:
    swept = feedback_sweep()
    items = feedback_items()
    pending = [i for i in items if i["state"] == "captured"]
    evaluated = [i for i in items if i["state"] == "evaluated"]
    print(json.dumps({
        "swept_expired": swept,
        "pending_evaluation": pending,
        "evaluated_unresolved": evaluated,
        "resolved": sum(1 for i in items if i["state"] == "resolved"),
        "ttl_days": FEEDBACK_TTL_DAYS,
    }, indent=2, ensure_ascii=False))
    return 0


def cmd_feedback_evaluate(args: argparse.Namespace) -> int:
    if args.verdict not in FEEDBACK_VERDICTS:
        print(json.dumps({"evaluated": False, "reason": f"verdict must be one of {sorted(FEEDBACK_VERDICTS)}"}))
        return 2
    evidence = (args.evidence or "").strip()
    if not evidence:
        print(json.dumps({"evaluated": False, "reason": "a verdict needs --evidence (what was checked, what it showed)"}))
        return 2
    known = {i["id"] for i in feedback_items()}
    if args.id not in known:
        print(json.dumps({"evaluated": False, "reason": f"unknown or expired id {args.id!r}"}))
        return 2
    ok = _feedback_append({
        "ts": _now_iso(),
        "event": "evaluate",
        "id": args.id,
        "verdict": args.verdict,
        "evidence": evidence[:500],
    })
    print(json.dumps({"evaluated": ok, "id": args.id, "verdict": args.verdict}))
    return 0 if ok else 1


def cmd_feedback_resolve(args: argparse.Namespace) -> int:
    if args.outcome not in FEEDBACK_OUTCOMES:
        print(json.dumps({"resolved": False, "reason": f"outcome must be one of {sorted(FEEDBACK_OUTCOMES)}"}))
        return 2
    known = {i["id"] for i in feedback_items()}
    if args.id not in known:
        print(json.dumps({"resolved": False, "reason": f"unknown or expired id {args.id!r}"}))
        return 2
    ok = _feedback_append({
        "ts": _now_iso(),
        "event": "resolve",
        "id": args.id,
        "outcome": args.outcome,
        "detail": (args.detail or "")[:500] or None,
    })
    print(json.dumps({"resolved": ok, "id": args.id, "outcome": args.outcome}))
    return 0 if ok else 1


# ---------------------------------------------------------------------------
# Hook entrypoints
# ---------------------------------------------------------------------------


def _read_payload() -> dict:
    try:
        doc = json.load(sys.stdin)
        return doc if isinstance(doc, dict) else {}
    except Exception:
        return {}


def _payload_cwd(payload: dict) -> pathlib.Path:
    cwd = payload.get("cwd")
    if isinstance(cwd, str) and cwd:
        return pathlib.Path(cwd)
    return pathlib.Path.cwd()


def _mark_command(plugin_root: str, session: str | None) -> str:
    session_arg = f" --session {session}" if session and session != "unknown" else ""
    return (
        f"\"{plugin_root}/bin/polymath-pipeline\" mark{session_arg} "
        f"--surface <skill-or-workflow-or-'direct'>"
    )


def _directive(mode: str, plugin_root: str, session: str | None = None) -> str:
    enforce_line = (
        " Mutating tool calls (Edit/Write, modify-pattern Bash, mutating "
        "MCP tools, Task) are GATED until that mark exists (fresh within "
        "the last hour)."
        if mode == "enforce"
        else ""
    )
    return (
        f"[polymath-pipeline] routing.mode={mode} for this repo. Before "
        f"substantial or mutating work on this request: (1) if a "
        f"[polymath-core route] hint appears above, it has precedence — "
        f"confirm and use that surface; (2) otherwise classify the request: "
        f"run polymath-pipeline:intake for an ambiguous or multi-step ask, "
        f"or just answer a trivial/conversational turn (that counts as "
        f"classified). (3) Record the classification: "
        f"{_mark_command(plugin_root, session)}.{enforce_line} Surfaces "
        f"declared `trust: auto-headless` that are read-only may be run "
        f"directly without propose-confirm in this mode (minimum "
        f"intervention). Kill switch (audited): POLYMATH_PIPELINE_OFF=1 or "
        f"touch .polymath/pipeline-off."
    )


def cmd_hook_session_start(args: argparse.Namespace) -> int:
    try:
        payload = _read_payload()
        root = resolve_root(_payload_cwd(payload))
        if root is None:
            return 0
        mode = read_mode(root)
        problems = config_diagnostics(root)
        if problems:
            for problem in problems:
                print(f"polymath-pipeline config error: {problem}")
            log_decision("config-error", root=str(root), problems=problems)
        if mode == "hint":
            return 0
        off = kill_switch(root)
        session = str(payload.get("session_id") or "")
        if off:
            log_decision("kill-switch", session=session, root=str(root), via=off, at="session-start")
            return 0
        sweep()
        print(
            f"polymath-pipeline: routing.mode={mode} active for {root} "
            f"(kill switch, audited: POLYMATH_PIPELINE_OFF=1 or "
            f".polymath/pipeline-off)."
        )
        return 0
    except Exception:
        log_decision("fail-open", at="session-start")
        return 0


def cmd_hook_prompt(args: argparse.Namespace) -> int:
    try:
        payload = _read_payload()
        root = resolve_root(_payload_cwd(payload))
        if root is None:
            return 0
        mode = read_mode(root)
        if mode == "hint":
            return 0
        session = str(payload.get("session_id") or "unknown")
        off = kill_switch(root)
        if off:
            log_decision("kill-switch", session=session, root=str(root), via=off, at="prompt")
            return 0
        touch_marker(session, root, mode)
        if fresh_classification(session, root):
            return 0  # already classified within the TTL — stay quiet
        plugin_root = os.environ.get(
            "CLAUDE_PLUGIN_ROOT",
            str(pathlib.Path(__file__).resolve().parent.parent),
        )
        print(_directive(mode, plugin_root, session))
        log_decision("classify-directive", session=session, root=str(root), mode=mode)
        return 0
    except Exception:
        log_decision("fail-open", at="prompt")
        return 0


def cmd_hook_pretool(args: argparse.Namespace) -> int:
    try:
        payload = _read_payload()
        root = resolve_root(_payload_cwd(payload))
        if root is None:
            return 0
        mode = read_mode(root)
        if mode != "enforce":
            return 0
        session = str(payload.get("session_id") or "unknown")
        off = kill_switch(root)
        if off:
            log_decision("kill-switch", session=session, root=str(root), via=off, at="pretool")
            return 0
        tool = str(payload.get("tool_name") or "")
        tool_input = payload.get("tool_input") or {}
        policy = load_tool_policy(root)
        if tool == "Bash":
            command = str(tool_input.get("command") or "") if isinstance(tool_input, dict) else ""
            if not bash_is_mutating(command, policy["bash_res"]):
                return 0  # read-only Bash is exempt (modify-pattern blacklist)
        elif tool.startswith("mcp__"):
            if not mcp_is_gated(tool, policy):
                return 0  # read-only MCP tool names are exempt
        elif tool not in policy["gated_tools"]:
            return 0
        if fresh_classification(session, root):
            return 0
        plugin_root = os.environ.get(
            "CLAUDE_PLUGIN_ROOT",
            str(pathlib.Path(__file__).resolve().parent.parent),
        )
        log_decision(
            "enforce-deny", session=session, root=str(root), tool=tool,
            detail=(str(tool_input.get("command", ""))[:200] if isinstance(tool_input, dict) else ""),
        )
        print(
            f"polymath-pipeline enforce: blocked {tool} — this repo gates "
            f"mutating tool calls (Edit/Write, modify-pattern Bash, mutating "
            f"MCP tools, Task) behind classification (routing.mode=enforce). "
            f"Classify first — run polymath-pipeline:intake "
            f"(ambiguous/multi-step) or decide the surface yourself — then "
            f"record it: {_mark_command(plugin_root, session)} and retry. "
            f"Read-only commands are exempt. Kill switch (audited): "
            f"POLYMATH_PIPELINE_OFF=1 or touch .polymath/pipeline-off.",
            file=sys.stderr,
        )
        return 2  # PreToolUse blocking contract
    except Exception:
        log_decision("fail-open", at="pretool")
        return 0


# ---------------------------------------------------------------------------
# CLI commands (model- and doctor-facing)
# ---------------------------------------------------------------------------


def cmd_mode(args: argparse.Namespace) -> int:
    root = resolve_root(pathlib.Path(args.cwd) if args.cwd else None)
    mode = read_mode(root) if root else "hint"
    print(json.dumps({
        "root": str(root) if root else None,
        "mode": mode,
        "config_errors": config_diagnostics(root) if root else [],
    }))
    return 0


def cmd_mark(args: argparse.Namespace) -> int:
    root = resolve_root(pathlib.Path(args.cwd) if args.cwd else None)
    if root is None:
        print(json.dumps({"marked": False, "reason": "no project root (.polymath/project.yaml) here"}))
        return 0
    mode = read_mode(root)
    if mode == "hint":
        print(json.dumps({"marked": False, "reason": "routing.mode is hint — nothing to mark"}))
        return 0
    if args.surface:
        accepted, reason = validate_surface(args.surface)
        if not accepted:
            log_decision("mark-rejected", root=str(root), surface=args.surface, reason=reason)
            print(json.dumps({"marked": False, "reason": reason}))
            return 2
    marker = mark_classified(root, args.surface, session=args.session)
    if marker is None:
        print(json.dumps({"marked": False, "reason": "marker store unwritable"}))
        return 0
    log_decision(
        "classified", session=marker.get("session"), root=str(root),
        surface=args.surface or "", mode=mode,
    )
    print(json.dumps({
        "marked": True,
        "root": str(root),
        "surface": args.surface or None,
        "session": marker.get("session"),
        "valid_for_seconds": CLASSIFIED_TTL_SECONDS,
    }))
    return 0


RECENT_EVENT_WINDOW = 200


def recent_event_counts(root: pathlib.Path | None) -> dict[str, int]:
    """Per-event counts over the newest RECENT_EVENT_WINDOW decision-log
    lines, scoped to this root (events without a root field — e.g.
    fail-open — always count)."""
    counts: dict[str, int] = {}
    try:
        lines = _log_path().read_text(errors="ignore").splitlines()[-RECENT_EVENT_WINDOW:]
    except OSError:
        return counts
    for line in lines:
        try:
            doc = json.loads(line)
        except Exception:
            continue
        if not isinstance(doc, dict):
            continue
        if root is not None and doc.get("root") not in (None, str(root)):
            continue
        event = str(doc.get("event") or "")
        if event:
            counts[event] = counts.get(event, 0) + 1
    return counts


def cmd_status(args: argparse.Namespace) -> int:
    root = resolve_root(pathlib.Path(args.cwd) if args.cwd else None)
    markers = []
    try:
        for path in sorted(_markers_dir().glob("*.json")):
            try:
                doc = json.loads(path.read_text())
                if isinstance(doc, dict):
                    markers.append(doc)
            except Exception:
                continue
    except OSError:
        pass
    log_lines = 0
    try:
        log_lines = sum(1 for _ in _log_path().open())
    except OSError:
        pass
    print(json.dumps({
        "root": str(root) if root else None,
        "mode": read_mode(root) if root else "hint",
        "config_errors": config_diagnostics(root) if root else [],
        "kill_switch": kill_switch(root),
        "markers": markers,
        "decision_log_lines": log_lines,
        "recent_events": recent_event_counts(root),
        "recent_event_window": RECENT_EVENT_WINDOW,
        "data_root": str(data_root()),
    }, indent=2))
    return 0


def cmd_sweep(args: argparse.Namespace) -> int:
    print(json.dumps(sweep()))
    return 0


def build_parser() -> argparse.ArgumentParser:
    p = argparse.ArgumentParser(
        prog="polymath-pipeline",
        description="Opt-in routing pipeline engine (classify/enforce).",
    )
    sub = p.add_subparsers(dest="cmd", required=True)

    pm = sub.add_parser("mode", help="print the resolved project root and routing.mode")
    pm.add_argument("--cwd")
    pm.set_defaults(func=cmd_mode)

    pk = sub.add_parser("mark", help="record that this request was classified (1h validity)")
    pk.add_argument("--surface", help="chosen surface: <plugin>:<skill>, workflow name, or 'direct'")
    pk.add_argument("--session", help="harness session id (the classify directive bakes it in)")
    pk.add_argument("--cwd")
    pk.set_defaults(func=cmd_mark)

    ps = sub.add_parser("status", help="markers + decision-log summary (doctor)")
    ps.add_argument("--cwd")
    ps.set_defaults(func=cmd_status)

    pw = sub.add_parser("sweep", help="run the retention sweep now")
    pw.set_defaults(func=cmd_sweep)

    pf = sub.add_parser("feedback", help="capture → evaluate → resolve localization feedback")
    fsub = pf.add_subparsers(dest="feedback_cmd", required=True)

    fc = fsub.add_parser("capture", help="record one feedback item (conservative; 180d TTL)")
    fc.add_argument("--surface", required=True, help="<plugin>:<skill>, workflow name, or 'direct'")
    fc.add_argument("--kind", required=True, help="correction | gap | friction | praise")
    fc.add_argument("--note", required=True, help="what happened, one screen max")
    fc.add_argument("--evidence", help="pointer to the artifact/run that shows it")
    fc.add_argument("--cwd")
    fc.set_defaults(func=cmd_feedback_capture)

    fd = fsub.add_parser("digest", help="sweep expired items and print the evaluation queue")
    fd.set_defaults(func=cmd_feedback_digest)

    fe = fsub.add_parser("evaluate", help="record a verdict for one item")
    fe.add_argument("id")
    fe.add_argument("--verdict", required=True, help="valid-constructive | valid-not-actionable | invalid")
    fe.add_argument("--evidence", required=True, help="what was checked and what it showed")
    fe.set_defaults(func=cmd_feedback_evaluate)

    fr = fsub.add_parser("resolve", help="record the final outcome for one item")
    fr.add_argument("id")
    fr.add_argument("--outcome", required=True, help="applied | rejected | proposed-catalog-patch")
    fr.add_argument("--detail", help="what was changed / why rejected / patch path")
    fr.set_defaults(func=cmd_feedback_resolve)

    for name, fn in (
        ("hook-session-start", cmd_hook_session_start),
        ("hook-prompt", cmd_hook_prompt),
        ("hook-pretool", cmd_hook_pretool),
    ):
        ph = sub.add_parser(name)
        ph.set_defaults(func=fn)

    return p


def main(argv: list[str] | None = None) -> int:
    args = build_parser().parse_args(argv)
    return args.func(args)


if __name__ == "__main__":
    sys.exit(main())
