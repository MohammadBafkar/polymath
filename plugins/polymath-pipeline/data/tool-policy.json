{
  "schemaVersion": 1,
  "description": "Base enforce-gate tool policy for polymath-pipeline. Machine-readable mirror of the engine's built-in constants (a unit test pins the two equal); read at hook time so an org fork can edit policy here without touching code. A project overlay at .polymath/tool-policy.json is STRENGTHEN-ONLY: it may add gatedTools, bashModifyPatterns, mcpGatedPatterns, or mcpMutatingVerbs — keys that would weaken the policy are ignored and audited to the decision log.",
  "gatedTools": [
    "Edit",
    "MultiEdit",
    "NotebookEdit",
    "Task",
    "Write"
  ],
  "bashModifyPatterns": [
    "[^<>]>{1,2}",
    "\\btee\\b",
    "\\b(rm|mv|cp|mkdir|rmdir|touch|ln|chmod|chown|truncate|dd|install)\\b",
    "\\b(sed|perl)\\b[^|;&]*\\s-[a-zA-Z]*i",
    "\\bgit\\b[^|;&]*\\b(commit|push|merge|rebase|reset|checkout|switch|restore|cherry-pick|revert|tag|stash|clean|am|apply|rm|mv|init|clone|fetch|pull|remote|submodule|worktree|branch\\s+(-d|-D|-m|-M))\\b",
    "\\b(npm|yarn|pnpm|pip3?|uv|poetry|cargo|gem|brew|apt(-get)?|dnf|yum|composer)\\b[^|;&]*\\b(install|add|remove|rm|uninstall|update|upgrade|publish)\\b",
    "\\bgo\\b[^|;&]*\\b(install|get|mod)\\b",
    "\\b(curl|wget)\\b[^|;&]*\\s(-o|-O|--output|--remote-name)\\b",
    "\\b(kill|pkill|killall)\\b",
    "\\b(docker|podman|kubectl|helm|terraform|pulumi)\\b[^|;&]*\\b(run|apply|delete|create|scale|patch|edit|exec|up|destroy|push|build|rm|prune)\\b",
    "\\b(systemctl|service|launchctl)\\b",
    "\\beval\\b|\\bexec\\b|\\bsource\\b|^\\s*\\.\\s",
    "\\bcrontab\\b",
    "(?:^|[|;&\\n])\\s*make\\b",
    "(?:^|[|;&\\n])\\s*(?:python3?|node|deno|bun|ruby|perl|bash|sh|zsh)\\b[^|;&\\n]*\\s\\S+\\.(?:py|js|mjs|cjs|ts|rb|pl|sh|bash)\\b",
    "(?:^|[|;&\\n])\\s*npx\\b",
    "\\bgh\\b[^|;&\\n]*\\s(?:create|merge|close|reopen|edit|delete|comment|review|fork|sync|enable|disable|rerun|cancel|deploy|ready|lock|unlock|transfer|api|clone|set|workflow\\s+run)\\b",
    "\\b(?:az|gcloud|aws)\\b[^|;&\\n]*\\s(?:create|delete|update|set|put|add|remove|start|stop|restart|deploy|scale|import|upload|purge|patch|assign|attach|detach|enable|disable|cp|mv|rm|sync|invoke|register|flush)\\b",
    "\\b(?:psql|mysql|sqlite3|mongosh?|redis-cli)\\b",
    "\\b(?:rsync|scp|sftp|unzip)\\b",
    "(?:^|[|;&\\n])\\s*patch\\b",
    "\\btar\\b\\s+-{0,2}[A-Za-z]*[xcur]"
  ],
  "mcpGatedPatterns": [],
