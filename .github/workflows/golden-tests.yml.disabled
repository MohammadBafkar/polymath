name: golden-tests

# DISABLED — live-model job only. This is the single golden-tests job that
# needs Claude auth (CLAUDE_CODE_OAUTH_TOKEN / ANTHROPIC_API_KEY) and so is
# kept off by default to avoid spending API budget on every push. See
# LIMITATIONS.md §4 for the re-enable runbook.
#
# The six token-free deterministic jobs that used to live here (unit tests,
# shipFeature e2e, hollow-run falsifiability anchor, golden-fixture frontmatter
# parse, skill-triggering frontmatter, bakeoff-cases parse) now run on every
# PR and push in .github/workflows/golden-deterministic.yml — they are NOT
# disabled.

on:
  pull_request:
  push:
    branches: [main]

permissions:
  contents: read

concurrency:
  group: golden-tests-${{ github.workflow }}-${{ github.event.pull_request.number || github.ref }}
  cancel-in-progress: true

jobs:
  claude-cli-fixtures:
    name: claude CLI fixture run
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "3.12"
      - run: pip install pyyaml
      - name: Detect Claude Code auth
        id: auth
        env:
          CLAUDE_CODE_OAUTH_TOKEN: ${{ secrets.CLAUDE_CODE_OAUTH_TOKEN }}
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
        run: |
          if [[ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" ]]; then
            echo "method=oauth" >> "$GITHUB_OUTPUT"
          elif [[ -n "${ANTHROPIC_API_KEY:-}" ]]; then
            echo "method=apikey" >> "$GITHUB_OUTPUT"
          else
            echo "method=none" >> "$GITHUB_OUTPUT"
          fi
      - name: Skip on PR with no auth (forks cannot read secrets)
        if: steps.auth.outputs.method == 'none' && github.event_name == 'pull_request'
        run: |
          echo "::warning::Neither CLAUDE_CODE_OAUTH_TOKEN nor ANTHROPIC_API_KEY"
          echo "::warning::is set on this PR (likely a fork). Skipping live fixtures."
          echo "::warning::Main-branch pushes require the secret and will fail without it."
      - name: Fail on main-branch push with no auth (hard gate)
        if: steps.auth.outputs.method == 'none' && github.event_name == 'push' && github.ref == 'refs/heads/main'
        run: |
          echo "::error::Main-branch push with no Claude auth available."
          echo "::error::The 9+ quality bar requires live golden fixtures on every"
          echo "::error::push to main. Set CLAUDE_CODE_OAUTH_TOKEN from a Claude.ai"
          echo "::error::subscription (preferred) or ANTHROPIC_API_KEY in repo secrets."
          exit 1
      - name: Install Claude Code CLI
        if: steps.auth.outputs.method != 'none'
        run: |
          npm install -g @anthropic-ai/claude-code
          claude --version
      - name: Run fixtures via tests/golden/run-fixtures.sh
        if: steps.auth.outputs.method != 'none'
        env:
          CLAUDE_CODE_OAUTH_TOKEN: ${{ secrets.CLAUDE_CODE_OAUTH_TOKEN }}
          ANTHROPIC_API_KEY: ${{ secrets.ANTHROPIC_API_KEY }}
        run: bash tests/golden/run-fixtures.sh
